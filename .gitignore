# Run outputs (per-task submissions, eval results, transcripts)
runs/
logs/

# Local recovery backups (pre-rerun eval JSONs, de-pollution originals) - multi-GB, never committed
backups/

# Cache (pulled cleanroom images, downloaded test blobs, ProgramBench python venv)
cache/
.venv/
__pycache__/
*.pyc

# Local OAuth token for sandbox-mode auth (gitignored — never commit).
.claude-oauth-token
.claude/scheduled_tasks.lock

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Keep the directory placeholders so the repo structure is obvious to cloners
!runs/.gitkeep
!logs/.gitkeep
!cache/.gitkeep
